<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/coursecatalog/db" VERSION="20250813" COMMENT="XMLDB file for Moodle local/coursecatalog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_coursecatalog" COMMENT="Custom pages for the local_coursecatalog plugin">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="slug" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="course_category" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="pagedescription" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Page description"/>
        <FIELD NAME="pagedescriptionformat" TYPE="int" LENGTH="1" NOTNULL="false" SEQUENCE="false" COMMENT="Page description format"/>
        <FIELD NAME="isenabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether the page is public or not"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timeupdated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Explicit display order for catalog pages"/>
        <FIELD NAME="showinprimarynavigation" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether to show the page in the navigation bar or not"/>
        <FIELD NAME="guestaccessible" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether the page is accessible to guests (not logged in users)"/>
        <FIELD NAME="includesubcategories" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether to include courses from subcategories"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="slug_uniq" TYPE="unique" FIELDS="slug"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_category_ix" UNIQUE="false" FIELDS="course_category"/>
        <INDEX NAME="sortorder_ix" UNIQUE="false" FIELDS="sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_coursecatalog_cats" COMMENT="Selected subcategories for a catalog page">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to local_coursecatalog.id"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to course_categories.id"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="pageid_fk" TYPE="foreign" FIELDS="pageid" REFTABLE="local_coursecatalog" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="pageid_categoryid_uix" UNIQUE="true" FIELDS="pageid,categoryid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
