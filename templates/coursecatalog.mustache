{{#pagedescription}}
<div class="mb-4">
    {{{pagedescription}}}
</div>
{{/pagedescription}}

<div class="d-flex flex-wrap justify-content-between align-items-center border-bottom py-3 mb-5 gap-4">
    <span class="fw-semibold fs-5">{{coursecount}}</span>
    <div class="d-flex align-items-center">
        <div class="btn-group btn-group-sm px-3" role="group" aria-label="{{#str}}viewmode, local_coursecatalog{{/str}}">
            <a href="{{gridurl}}"
               class="btn {{#isgrid}}btn-secondary{{/isgrid}}{{^isgrid}}btn-outline-secondary{{/isgrid}}"
               title="{{#str}}viewgrid, local_coursecatalog{{/str}}">
                <i class="fa fa-th" aria-hidden="true"></i>
            </a>
            <a href="{{listurl}}"
               class="btn {{#islist}}btn-secondary{{/islist}}{{^islist}}btn-outline-secondary{{/islist}}"
               title="{{#str}}viewlist, local_coursecatalog{{/str}}">
                <i class="fa fa-list" aria-hidden="true"></i>
            </a>
        </div>
        <span class="vr mx-2"></span>
        <form method="get" action="{{sort.action}}" class="d-flex align-items-center gap-2 px-3">
            <input type="hidden" name="slug" value="{{sort.slug}}">
            <input type="hidden" name="view" value="{{view}}">
            <label for="sortby-select" class="form-label mb-0 small text-nowrap">
                {{#str}}sortby, local_coursecatalog{{/str}}
            </label>
            <select id="sortby-select" name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
                {{#sort.options}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/sort.options}}
            </select>
        </form>
    </div>
</div>

{{! Grid view }}
{{#isgrid}}
<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
    {{#courses}}
    <div class="col">
        <div class="card h-100 shadow-sm border-0 rounded-3">
            {{#courseimage}}
            <img src="{{courseimage}}"
                 class="card-img-top rounded-top-3"
                 alt="{{fullname}}"
                 style="height: 180px; object-fit: cover;">
            {{/courseimage}}
            {{^courseimage}}
            <div class="bg-light rounded-top-3 d-flex align-items-center justify-content-center"
                 style="height: 120px;">
                <i class="fa fa-graduation-cap fa-3x text-muted" aria-hidden="true"></i>
            </div>
            {{/courseimage}}
            <div class="card-body d-flex flex-column">
                <h5 class="card-title h6 mb-2">
                    <a href="{{buttonurl}}" class="text-decoration-none fw-semibold stretched-link">
                        {{fullname}}
                    </a>
                </h5>
                <div class="card-text small text-muted flex-grow-1 mb-3">
                    {{summary}}
                </div>
                <div class="d-flex justify-content-between align-items-center pt-2 border-top mt-auto">
                    <small class="text-muted">
                        {{modulescount}} &bull; {{activitycount}}
                    </small>
                    <span class="badge text-bg-primary rounded-pill">{{buttontext}}</span>
                </div>
            </div>
        </div>
    </div>
    {{/courses}}

    {{^courses}}
    <div class="col-12">
        <div class="alert alert-info mb-0">
            {{#str}}nocoursesinthiscategory, local_coursecatalog{{/str}}
        </div>
    </div>
    {{/courses}}
</div>
{{/isgrid}}

{{! List view }}
{{#islist}}
<div class="d-flex flex-column gap-5 py-2">
    {{#courses}}
    <div class="card shadow-sm border-0 rounded-3 mb-2">
        <div class="row g-0">
            {{#courseimage}}
            <div class="col-4 col-md-3 col-lg-2">
                <img src="{{courseimage}}"
                     class="img-fluid rounded-start-3 w-100 h-100"
                     alt="{{fullname}}"
                     style="object-fit: cover; min-height: 140px; max-height: 200px;">
            </div>
            {{/courseimage}}
            {{^courseimage}}
            <div class="col-auto">
                <div class="bg-light rounded-start-3 d-flex align-items-center justify-content-center h-100"
                     style="width: 80px;">
                    <i class="fa fa-graduation-cap fa-2x text-muted" aria-hidden="true"></i>
                </div>
            </div>
            {{/courseimage}}
            <div class="col">
                <div class="card-body d-flex flex-column h-100">
                    <h5 class="card-title h6 mb-1">
                        <a href="{{buttonurl}}" class="text-decoration-none fw-semibold stretched-link">
                            {{fullname}}
                        </a>
                    </h5>
                    <div class="card-text small text-muted flex-grow-1 mb-3">
                        {{summary}}
                    </div>
                    <div class="d-flex justify-content-between align-items-center pt-2 border-top mt-auto">
                        <small class="text-muted">
                            {{modulescount}} &bull; {{activitycount}}
                        </small>
                        <span class="badge text-bg-primary rounded-pill">{{buttontext}}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{/courses}}

    {{^courses}}
    <div class="alert alert-info mb-0">
        {{#str}}nocoursesinthiscategory, local_coursecatalog{{/str}}
    </div>
    {{/courses}}
</div>
{{/islist}}
